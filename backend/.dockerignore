*.swp
*.swo
.vscode
.idea
Thumbs.db

# Test & coverage output
coverage
__tests__
*.test.ts
*.spec.ts
jest.config.*

# CI/CD
.github

# Docker files themselves
Dockerfile
.dockerignore

# Logs
*.log
npm-debug.log*
