        {
          "name": "Get All Listings",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/listings?page=1&limit=10&type=apartment&min_price=500&max_price=2000",
              "host": ["{{base_url}}"],
              "path": ["api", "listings"],
              "query": [
                {
                  "key": "page",
                  "value": "1",
                  "disabled": false
                },
                {
                  "key": "limit",
                  "value": "10",
                  "disabled": false
                },
                {
                  "key": "type",
                  "value": "apartment",
                  "disabled": true
                },
                {
                  "key": "min_price",
                  "value": "500",
                  "disabled": true
                },
                {
                  "key": "max_price",
                  "value": "2000",
                  "disabled": true
                },
                {
                  "key": "location",
                  "value": "Downtown",
                  "disabled": true
                }
              ]
            },
            "description": "Retrieve all active property listings with optional filtering"
          },
          "response": []
        },
        {
          "name": "Get Single Listing",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/listings/1",
              "host": ["{{base_url}}"],
              "path": ["api", "listings", "1"]
            },
            "description": "Retrieve detailed information for a specific listing"
          },
          "response": []
        },
        {
          "name": "Create Listing",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  var jsonData = pm.response.json();",
                  "  pm.environment.set('listing_id', jsonData.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{auth_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Modern Apartment in Downtown\",\n  \"description\": \"Beautiful 2-bedroom apartment with river views\",\n  \"price\": 1500.00,\n  \"location\": \"Downtown\",\n  \"property_type\": \"apartment\",\n  \"bedrooms\": 2,\n  \"bathrooms\": 1,\n  \"square_feet\": 900,\n  \"amenities\": [\"WiFi\", \"Parking\", \"Gym\", \"Laundry\"]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/listings",
              "host": ["{{base_url}}"],
              "path": ["api", "listings"]
            },
            "description": "Create a new property listing"
          },
          "response": []
        },
        {
          "name": "Update Listing",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{auth_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Title\",\n  \"price\": 1600.00,\n  \"status\": \"published\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/listings/{{listing_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "listings", "{{listing_id}}"]
            },
            "description": "Update an existing listing (owner only)"
          },
          "response": []
        },
        {
          "name": "Delete Listing",
