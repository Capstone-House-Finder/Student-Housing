# Dependencies — reinstalled inside the container
node_modules

# Next.js build output — rebuilt inside the container
.next
out

# Environment files — secrets must never be baked into the image
.env
.env.*
!.env.example

# Version control
.git
.gitignore

# Editor & OS artefacts
.DS_Store
*.swp
*.swo
.vscode
.idea
Thumbs.db

# Test & coverage output
coverage
__tests__
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx
jest.config.*
jest.setup.*

# CI/CD
.github

# Docker files themselves (no need to copy into the image)
Dockerfile
.dockerignore

# Logs
*.log
npm-debug.log*
