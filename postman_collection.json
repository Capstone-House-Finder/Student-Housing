                {
                  "key": "token",
                  "value": "{{auth_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/listings/{{listing_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "listings", "{{listing_id}}"]
            },
            "description": "Soft-delete a listing"
          },
          "response": []
        }
      ]
