# ══════════════════════════════════════════════════════════════════════════════
# .env.example — Student Housing Platform
# Copy this file to .env and fill in the values for your environment.
# NEVER commit .env to version control.
# ══════════════════════════════════════════════════════════════════════════════

# ── Environment ───────────────────────────────────────────
NODE_ENV=development         # development | staging | production

# ── MySQL ─────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=         # strong root password
MYSQL_DATABASE=student_housing
MYSQL_USER=appuser
MYSQL_PASSWORD=              # strong app user password
MYSQL_PORT=3306              # host port to expose (local dev only)

# ── Backend ───────────────────────────────────────────────
BACKEND_PORT=5000
DATABASE_URL=mysql://appuser:MYSQL_PASSWORD@mysql:3306/student_housing

# Auth
JWT_SECRET=                  # generate with: openssl rand -hex 64

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email (Nodemailer)
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USER=apikey
EMAIL_PASSWORD=              # SendGrid API key or SMTP password

# ── Frontend ──────────────────────────────────────────────
FRONTEND_PORT=3000

# Inlined into the Next.js client bundle at build time.
# In Docker Compose the rewrite proxy handles routing so this points
# to the public-facing API domain in staging/prod.
NEXT_PUBLIC_API_URL=http://localhost:5000
